{
  "format_version": "1.10.0",
  "animation_controllers": {
    "controller.animation.kingdoms.villager.move": {
      "initial_state": "idle",
      "states": {
        "idle": {
          "animations": [ "idle" ],
          "blend_transition": 0.2,
          "transitions": [
            { "walking": "query.modified_move_speed > 0.0" }
          ]
        },
        "walking": {
          "animations": [ "walk" ],
          "blend_transition": 0.2,
          "transitions": [
            { "idle": "query.modified_move_speed <= 0.0" }
          ]
        }
      }
    }
  }
}
