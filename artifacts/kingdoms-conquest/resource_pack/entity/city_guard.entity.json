{
  "format_version": "1.10.0",
  "minecraft:client_entity": {
    "description": {
      "identifier": "kingdoms:city_guard",
      "min_engine_version": "1.16.0",
      "materials": {
        "villager": "entity_alphatest"
      },
      "textures": {
        "default": "textures/piki/vd/entity/villager_warrior"
      },
      "geometry": {
        "default": "geometry.piki_villagedefense.villager"
      },
      "animations": {
        "idle": "animation.piki_villagedefense.villager.idle",
        "walk": "animation.piki_villagedefense.villager.walk",
        "run": "animation.piki_villagedefense.villager.run",
        "attack": "animation.piki_villagedefense.villager.attack"
      },
      "scripts": {
        "animate": [
          { "run": "query.modified_move_speed >= 0.34" },
          { "walk": "query.modified_move_speed >= 0.1 && query.modified_move_speed < 0.34" },
          { "attack": "query.is_attacking" },
          "idle"
        ]
      },
      "render_controllers": [
        "controller.render.kingdoms.soldier"
      ],
      "spawn_egg": {
        "texture": "city_guard_spawn_egg",
        "texture_index": 0
      }
    }
  }
}