{
	"format_version": "1.20.80",
	"minecraft:block": {
		"description": {
			"identifier": "faye:flower_light2",
			"traits":{
				"minecraft:placement_direction": {
					"enabled_states": ["minecraft:cardinal_direction"],
					"y_rotation_offset": 0
                }
            },
			"states": {
                "faye:interact":[false,true]
			},
			"menu_category": {
				"category": "construction",
				"group": "itemGroup.name.construction"
			}
		},
		"components": {
			"minecraft:geometry": "geometry.flower_light2",
			"minecraft:material_instances": {
				"*": {
					"texture": "flower_light2",
					"render_method": "alpha_test"
				}
			},
			"minecraft:light_emission": 0,
			"minecraft:light_dampening": 0,
			"minecraft:destructible_by_mining": {
				"seconds_to_destroy": 0.4
			},
			"tag:light": {},
			"minecraft:selection_box": {
				"origin": [-8,0,6],
				"size": [16,16,2]
			},
			"minecraft:collision_box": {
				"origin": [-8,0,6],
				"size": [16,16,2]
			},
			"minecraft:tick": {
				"interval_range": [70,70],
				"looping": true
			},
			"minecraft:custom_components": [
			  "faye:open",
			  "faye:close"
			]
		},
		"permutations": [
            {
				"condition": "query.block_state('faye:interact') == false",
				"components": {
                    "minecraft:custom_components": [
                      "faye:open"
                    ],
			        "minecraft:light_emission": 15,
			        "minecraft:material_instances": {
				        "*": {
					        "texture": "flower_light2",
					        "render_method": "alpha_test"
				        }
			        }
				}
            },
            {
				"condition": "query.block_state('faye:interact') == true",
				"components": {
                    "minecraft:custom_components": [
                      "faye:close"
                    ],
                    "minecraft:tick": {
                        "interval_range": [101,101],
                        "looping": false
                    },
			        "minecraft:light_emission": 0,
			        "minecraft:material_instances": {
				        "*": {
					        "texture": "flower_light2",
					        "render_method": "alpha_test"
				        }
				    }
				}
            },
			{
				"condition": "q.block_state('minecraft:cardinal_direction') == 'north' ",
				"components": {
					"minecraft:transformation": {
						"rotation": [0, 180, 0],
				        "translation": [0, 0, 0],
				        "scale": [1.0, 1.0, 1.0]
					}
				}
			},
			{
				"condition": "q.block_state('minecraft:cardinal_direction') == 'south' ",
				"components": {
					"minecraft:transformation": {
						"rotation": [0, 0, 0],
				        "translation": [0, 0, 0],
				        "scale": [1.0, 1.0, 1.0]
					}
				}
			},
			{
				"condition": "q.block_state('minecraft:cardinal_direction') == 'east' ",
				"components": {
					"minecraft:transformation": {
						"rotation": [0, 90, 0],
				        "translation": [0, 0, 0],
				        "scale": [1.0, 1.0, 1.0]
					}
				}
			},
			{
				"condition": "q.block_state('minecraft:cardinal_direction') == 'west' ",
				"components": {
					"minecraft:transformation": {
						"rotation": [0, 270, 0],
				        "translation": [0, 0, 0],
				        "scale": [1.0, 1.0, 1.0]
					}
				}
			}
		]
	}
}