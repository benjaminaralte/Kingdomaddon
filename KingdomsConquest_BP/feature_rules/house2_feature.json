{
    "format_version": "1.13.0",
    "minecraft:feature_rules": {
        "description": {
            "identifier": "mst:house2_feature", 
            "places_feature": "mst:house2_feature"  
        },
        "conditions": {
            "placement_pass": "first_pass",
"minecraft:biome_filter": [
  {
    "test": "has_biome_tag",
    "operator": "==",
    "value": "desert"
  }
]

        },
        "distribution": {
            "iterations": 1,
            "x": {
                "extent": [0, 16],
                "distribution": "uniform"
            },
            "y": "q.heightmap(v.worldx, v.worldz)",
            "z": {
                "extent": [0, 16],
                "distribution": "uniform"
            },
            "scatter_chance": {
                "numerator": 1,
                "denominator": 800
            }
        }
    }
}
